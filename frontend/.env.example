
# OMDB API — Movie metadata (title, poster, cast, rating, plot)
# Get your free key at: https://omdbapi.com
# Free tier: 1,000 requests/day
# ─────────────────────────────────────────────
OMDB_API_KEY=your_omdb_api_key_here

# ─────────────────────────────────────────────
# Groq API — AI sentiment analysis (llama-3.1-8b-instant)
# Get your free key at: https://console.groq.com
# Free tier: 14,400 requests/day · 30 RPM
# ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─────────────────────────────────────────────
# MongoDB Atlas — Response cache (M0 free cluster)
# Get started: https://mongodb.com/atlas
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/movie-insight
# ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/movie-insight
